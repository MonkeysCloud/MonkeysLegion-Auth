{
    "name": "monkeyscloud/monkeyslegion-auth",
    "description": "High-performance authentication & authorization: multi-guard, JWT, RBAC, OAuth, 2FA, API keys, passkeys",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "MonkeysCloud",
            "email": "jorge@monkeys.cloud"
        }
    ],
    "require": {
        "php": "^8.4",
        "firebase/php-jwt": "^7.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "suggest": {
        "ext-redis": "Required for Redis-based rate limiting and token storage",
        "ext-openssl": "Required for RS256/ES256 asymmetric JWT signing",
        "monkeyscloud/monkeyslegion-database": "Database-backed user providers and RBAC storage",
        "monkeyscloud/monkeyslegion-cli": "CLI commands for auth management",
        "nyholm/psr7": "PSR-7 implementation for middleware responses"
    },
    "autoload": {
        "psr-4": {
            "MonkeysLegion\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MonkeysLegion\\Auth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src tests --level=9"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-2.x": "2.0.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
